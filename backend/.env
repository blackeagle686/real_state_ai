 PROJECT_NAME="Real Estate AI Assistant"
VERSION="1.0.0"

# Vector DB Configuration
VECTOR_DB_TYPE="chroma"
CHROMA_PERSIST_DIR="./chroma_db"

# LLM Configuration (Long Cat / OpenAI Compatible)
# User should provide their actual key in Colab
OPENAI_API_KEY="ak_2yp3Xw1Ny7ky2pF7er9x93ZO9jj6G"
OPENAI_BASE_URL="https://api.longcat.chat/openai"

# Memory Configuration
REDIS_HOST="localhost"
REDIS_PORT=6379

# Disable VLM
ENABLE_VLM=false

# Disable Local Models in IRYM_sdk
LOCAL_LLM_TEXT_MODEL=""
LOCAL_VLM_MODEL=""
LOAD_LOCAL_LLM=true
LOAD_LOCAL_VLM=false
AUTO_ACCEPT_FALLBACK=true

# Token & Security Limits
SECURITY_MAX_INPUT_LENGTH=4096
SECURITY_MAX_OUTPUT_LENGTH=2048
SECURITY_ENABLE_HALLUCINATION_CHECK=false

# RAG Optimizations
RAG_QUERY_EXPANSION=true
RAG_HYDE_ENABLED=true
RAG_MMR_ENABLED=true
RAG_MMR_LAMBDA=0.5
RAG_MAX_CONTEXT_CHUNKS=5
RAG_CONTEXT_COMPRESSION=true

# Parent-Child Retrieval (Advanced RAG)
RAG_PARENT_RETRIEVAL=true
RAG_PARENT_CHUNK_SIZE=1500
RAG_CHILD_CHUNK_SIZE=300
RAG_CHUNK_OVERLAP=50
