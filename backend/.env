PROJECT_NAME="Real Estate AI Assistant"
VERSION="1.0.0"

# Vector DB Configuration
VECTOR_DB_TYPE="chroma"
CHROMA_PERSIST_DIR="./chroma_db"

# LLM Configuration (Long Cat / OpenAI Compatible)
# User should provide their actual key in Colab
OPENAI_API_KEY="sk-replace-this-on-colab"
OPENAI_BASE_URL="https://api.longcat.io/v1"

# Memory Configuration
REDIS_HOST="localhost"
REDIS_PORT=6379

# Disable VLM
ENABLE_VLM=false

# Disable Local Models in IRYM_sdk
LOCAL_LLM_TEXT_MODEL=""
LOCAL_VLM_MODEL=""
LOAD_LOCAL_LLM=false
LOAD_LOCAL_VLM=false
